# Hyperliquid API
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=

# Database (PostgreSQL recommended; ClickHouse supported)
DB_URL=postgresql+asyncpg://arb:arb@localhost:5432/arb

# Redis (optional, only for live state sharing)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Paper trading
PAPER_TRADE=true

# Risk defaults (per-market notional cap USD)
RISK_SINGLE_MARKET_CAP=5000
RISK_PORTFOLIO_GROSS_CAP=20000
RISK_PER_TRADE_LOSS_CAP=100
RISK_MAX_CONCURRENT_SPREADS=5
RISK_MAX_HOLD_MINUTES=240
